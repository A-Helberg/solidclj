{:paths ["src"]
 :deps {org.clojure/clojure       {:mvn/version "1.12.3"}
        org.clojure/clojurescript {:mvn/version "1.11.132"}
        com.cognitect/transit-clj  {:mvn/version "1.0.333"}
        com.cognitect/transit-cljs {:mvn/version "0.8.280"}
        juji/editscript {:mvn/version "0.7.0"}
        missionary/missionary {:mvn/version "b.47"}
        solidjclj/solidclj {:local/root "../solidclj/"}}

 :aliases
 {:cljs {:extra-deps {thheller/shadow-cljs {:mvn/version "2.28.17"}}}

  :test {:extra-paths ["test"]
         :extra-deps  {aleph/aleph         {:mvn/version "0.9.0"}
                       com.taoensso/timbre {:mvn/version "6.6.2"}
                       io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"
                       "-d" "test"]}

  ;; Peer deps — consumers supply their own server stack.
  :server {:extra-deps {aleph/aleph          {:mvn/version "0.9.0"}
                        com.taoensso/timbre  {:mvn/version "6.6.2"}}}}}

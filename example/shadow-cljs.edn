{:deps {:aliases [:cljs]}
 :dev-http {8080 {:root "resources/public"}}
 :builds
 {:app {:target     :browser
        :output-dir "resources/public/js"
        :asset-path "/js"
        :modules    {:app {:init-fn frontend.core/init}}
        :devtools   {:watch-dir "resources/public"
                     :proxy-url "http://localhost:3000"}}}}

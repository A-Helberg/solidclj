{
	http_port 1080
	https_port 1443
	servers {
		protocols h1 h2 h3
	}
}

:1443 {
	tls ./certs/localhost.pem ./certs/localhost-key.pem

	header Alt-Svc "h3=\":1443\"; ma=2592000"

	handle /* {
		reverse_proxy http://localhost:1300 {
			transport http {
				versions 1.1
			}
		}
	}

        # Logging for debug
	# log {
	# 	output stdout
	# 	format console
	# 	level INFO
	# }
}

:1080 {
	redir https://localhost:1443{uri}
}
